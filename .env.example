# Veracode API credentials (or use ~/.veracode/credentials file)
VERACODE_API_KEY_ID=your-veracode-api-id
VERACODE_API_KEY_SECRET=your-veracode-api-key

# Optional: path to Veracode CLI binary (default: "veracode")
VERACODE_CLI_PATH=veracode

# Optional: scan timeout in milliseconds (default: 300000 = 5 min)
SCAN_TIMEOUT_MS=300000
